# ==========================================
# InvoiceOS AI - Environment Variables
# ==========================================

# 1. Supabase (Database & Auth)
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# REQUIRED FOR ADMIN & CRON JOBS: Get this from Supabase Project Settings -> API (Service Role Secret)
# Keep this secret! Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 2. Next.js Public URL
# Your production URL or local dev URL (e.g., http://localhost:3000)
# Used for Stripe Connect redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 3. Stripe (Payments & Billing)
# Get these from your Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Connect Client ID
# Found in Stripe Settings -> Connect -> Settings -> Integration
NEXT_PUBLIC_STRIPE_CLIENT_ID=ca_...

# Webhook Secrets
# You need TWO webhooks configured in Stripe:
# 1. Standard Webhook (For your SaaS Subscriptions)
STRIPE_WEBHOOK_SECRET=whsec_...
# 2. Connect Webhook (For Invoice Payments on Connected Accounts)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# 4. Email Reminders (Resend)
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# 5. Admin & Security
# Your personal email. Grants access to the /admin dashboard.
ADMIN_EMAIL=you@yourdomain.com

# Cron Job Secret (Required for Vercel Cron)
# A random string used to secure your cron endpoints. 
# Generate one using `openssl rand -base64 32` or just make up a strong password.
CRON_SECRET=super_secret_cron_key_123
